PORT=4173
NODE_ENV=development
SESSION_SECRET=replace-with-a-long-random-secret-before-deploying

# Email verification through Resend
RESEND_API_KEY=re_your_private_key
RESEND_FROM=Hive <verify@your-verified-domain.com>

# Keep this server-only. Never put it in React files or upload .env to GitHub.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.6
