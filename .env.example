# Use a long, random value before deploying this app.
SESSION_SECRET=replace-this-with-a-long-random-secret
PORT=3000
NODE_ENV=development

# Add these after creating a Resend account. Keep this file private.
RESEND_API_KEY=re_your_private_api_key
# This must use a domain you have verified in Resend, for example:
RESEND_FROM=Hive <verify@yourdomain.com>
