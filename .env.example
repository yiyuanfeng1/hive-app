PORT=4173
NODE_ENV=development
SESSION_SECRET=replace-this-with-a-long-random-secret

# Email verification through Resend. Use the API key from your Resend account.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Hive <onboarding@resend.dev>

# Keep this server-only. Never put it in React files or upload .env to GitHub.
GEMINI_API_KEY=AIza_your_gemini_api_key
GEMINI_MODEL=your-supported-gemini-model
